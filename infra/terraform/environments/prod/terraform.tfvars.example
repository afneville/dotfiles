# Provide interactively, with the flag -var-file="example.tfvars", copy to terraform.tfvars or supply at the command line with -var="key=value"
hosted_zone_id = ""
hosted_zone    = "afneville.com"

wkd_bucket_name     = "afneville.com"
wkd_domain_names    = ["afneville.com", "www.afneville.com"]
vps_vpn_hostname    = "vpn.afneville.com"

vps_name                = "services"
vps_instance_type       = "t3.large"
vps_root_volume_size_gb = 20
vps_data_volume_size_gb = 100

# Inline value is favoured over file
vps_ssh_public_key      = ""
vps_ssh_public_key_file = "key.pub"

# Access may be required during bootstrap
vps_ssh_ingress_enabled   = false
vps_admin_ssh_cidr_blocks = ["0.0.0.0/0"]
vps_http_ingress_enabled  = false
